{
  "name": "ts-ddng-client",
  "version": "0.0.1",
  "description": "TypeScript client library for the drebedengi.ru personal finance SOAP API",
  "author": "David Galoyan <davojan@gmail.com>",
  "license": "MIT",
  "repository": "git+https://github.com/davojan/ts-ddng-client.git",
  "packageManager": "pnpm@11.7.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "ddng"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "clean": "rimraf coverage dist es lib",
    "compile": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"*.{json,md,mjs}\"",
    "lint": "eslint src test --max-warnings=0",
    "lint:fix": "eslint src test --fix",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "keywords": [
    "api",
    "client",
    "drebedengi",
    "finance",
    "library",
    "soap",
    "typescript"
  ],
  "dependencies": {
    "strong-soap": "6.0.0",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.0",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.6.0",
    "prettier": "3.9.4",
    "rimraf": "6.1.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "4.1.10"
  }
}
